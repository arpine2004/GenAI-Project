# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional, enables LLaMA model comparison tab
GROQ_API_KEY=your_groq_api_key_here

# Optional, enables image generation tab
HF_TOKEN=your_huggingface_token_here

# Model settings (defaults available below)
CLAUDE_MODEL=claude-haiku-4-5-20251001
CLAUDE_ALT_MODEL=claude-opus-4-6
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.1

# Local model settings
WHISPER_MODEL=openai/whisper-base
QG_MODEL=google/flan-t5-base
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
IMAGE_GEN_MODEL=black-forest-labs/FLUX.1-schnell

# Chunking & retrieval
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.0
SUMMARIZE_MAX_CHUNKS=500

# Performance
TOKENIZERS_PARALLELISM=false
